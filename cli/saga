#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# Saga Minimal Installer (Fedora-first)
# - Installs baseline Hyprland stack in controlled stages.
# - Copies Saga's baseline Hypr config directly into ~/.config/hypr/hyprland.conf.
# - Keeps uninstall targeted to Saga-related files/packages.
###############################################################################

# Resolve repository root robustly:
# - handles direct execution: ./cli/saga
# - handles symlinked execution: ~/.local/bin/saga -> <repo>/cli/saga
SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH" 2>/dev/null || echo "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="${SAGA_REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
# Fallback for ad-hoc runs where current directory is the repo root.
if [[ ! -f "$REPO_ROOT/desktop/hypr/hyprland.conf" && -f "$PWD/desktop/hypr/hyprland.conf" ]]; then
  REPO_ROOT="$PWD"
fi
SAGA_SHARE_DIR="$HOME/.local/share/saga"
SAGA_CACHE_DIR="$HOME/.cache/saga"
HYPR_CONFIG_DIR="$HOME/.config/hypr"
HYPR_CONFIG_FILE="$HYPR_CONFIG_DIR/hyprland.conf"
SAGA_HYPR_CONFIG_SOURCE="$REPO_ROOT/desktop/hypr/hyprland.conf"

DISTRO=""
PKG_MANAGER=""

# Package/runtime checks are represented as: package_name|command_name.
REQUIRED_COMPONENTS=(
  "hyprland|Hyprland"
  # Future baseline additions (disabled for now):
  # "pipewire|pipewire"
  # "wireplumber|wireplumber"
  # "xdg-desktop-portal-hyprland|xdg-desktop-portal-hyprland"
  # "wl-clipboard|wl-copy"
  # "grim|grim"
  # "slurp|slurp"
  "kitty|kitty"
  "swww|swww"
  "waybar|waybar"
)

# Full package cleanup set for uninstall (Fedora stage).
# Keep this broader than the active install set so uninstall can clean older Saga attempts too.
UNINSTALL_PACKAGES=(
  hyprland
  pipewire
  wireplumber
  xdg-desktop-portal-hyprland
  wl-clipboard
  grim
  slurp
  kitty
  waybar
  walker
  eww
  swaynotificationcenter
  swww
  hyprlock
  hypridle
)

usage() {
  cat <<USAGE
Usage:
  ./cli/saga install
  ./cli/saga uninstall
  ./cli/saga doctor
USAGE
}

###############################################################################
# Platform detection
###############################################################################

# Detect supported distro from /etc/os-release.
detect_distro() {
  if [[ ! -r /etc/os-release ]]; then
    echo "[ERROR] Cannot detect distro: /etc/os-release not found" >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  DISTRO="${ID:-unknown}"

  case "$DISTRO" in
    fedora)
      ;;
    *)
      echo "[ERROR] Unsupported distro: $DISTRO" >&2
      echo "[INFO] Currently supported: fedora" >&2
      exit 1
      ;;
  esac
}

# Resolve package manager for current distro.
detect_package_manager() {
  case "$DISTRO" in
    fedora)
      PKG_MANAGER="dnf"
      ;;
    *)
      echo "[ERROR] No package manager mapping for distro: $DISTRO" >&2
      exit 1
      ;;
  esac

  if ! command -v "$PKG_MANAGER" >/dev/null 2>&1; then
    echo "[ERROR] Package manager '$PKG_MANAGER' not found" >&2
    exit 1
  fi
}

###############################################################################
# Package install helpers
###############################################################################

# Return success if package is already installed.
is_package_installed() {
  local pkg="$1"
  case "$PKG_MANAGER" in
    dnf)
      rpm -q "$pkg" >/dev/null 2>&1
      ;;
    *)
      return 1
      ;;
  esac
}

# Install a package safely:
# - skip if package metadata is unavailable
# - warn on unknown package manager
install_pkg() {
  local pkg="$1"

  case "$PKG_MANAGER" in
    dnf)
      if dnf info "$pkg" >/dev/null 2>&1; then
        echo "[INSTALLING] $pkg"
        sudo dnf install -y "$pkg"
      else
        echo "[SKIP] $pkg not available"
      fi
      ;;
    *)
      echo "[WARN] Unknown package manager"
      ;;
  esac
}

# Idempotent install of one package.
install_single_package() {
  local pkg="$1"

  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
    return 0
  fi

  install_pkg "$pkg"
  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
  else
    echo "[SKIP] $pkg not installed"
  fi
}

# Install all active required packages.
install_packages() {
  local item pkg
  for item in "${REQUIRED_COMPONENTS[@]}"; do
    pkg="${item%%|*}"
    install_single_package "$pkg"
  done
}

###############################################################################
# Hyprland config generation
###############################################################################

# Write ~/.config/hypr/hyprland.conf directly from Saga's baseline source.
write_base_hyprland_conf() {
  local dest="$1"
  cat > "$dest" <<'EOF'
# Saga baseline Hyprland config
# This file is intentionally minimal and fully controlled by Saga.

monitor=,preferred,auto,1

# App/command variables (edit commands here)
$terminal_app = kitty
$launcher_app = walker
$control_center_app = saga panel toggle control_center
$notifications_app = swaync-client -t
$wifi_app = saga panel toggle wifi_menu
$bluetooth_app = saga panel toggle bluetooth_menu
$audio_app = saga panel toggle audio_menu
$brightness_app = saga panel toggle brightness_menu
$system_stats_app = saga panel toggle system_stats
$power_app = saga panel toggle power_menu
$file_search_app = saga launcher files

exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec-once = swww-daemon
exec-once = waybar

input {
    kb_layout = us
}

bind = SUPER, Q, killactive
bind = SUPER, M, exit

bind = SUPER, T, exec, $terminal_app
bind = SUPER, SPACE, exec, $launcher_app
bind = SUPER ALT, C, exec, $control_center_app
bind = SUPER ALT, N, exec, $notifications_app
bind = SUPER ALT, W, exec, $wifi_app
bind = SUPER ALT, B, exec, $bluetooth_app
bind = SUPER ALT, V, exec, $audio_app
bind = SUPER ALT, L, exec, $brightness_app
bind = SUPER ALT, I, exec, $system_stats_app
bind = SUPER ALT, P, exec, $power_app
bind = SUPER ALT, F, exec, $file_search_app

misc {
    disable_hyprland_qtutils_check = true
}
EOF
}

install_config() {
  mkdir -p "$HYPR_CONFIG_DIR" "$SAGA_SHARE_DIR" "$SAGA_CACHE_DIR"
  if [[ -f "$SAGA_HYPR_CONFIG_SOURCE" ]]; then
    cp "$SAGA_HYPR_CONFIG_SOURCE" "$HYPR_CONFIG_FILE"
  else
    echo "[WARN] Missing Saga Hyprland baseline config: $SAGA_HYPR_CONFIG_SOURCE" >&2
    echo "[INFO] Generating base Hyprland config directly at $HYPR_CONFIG_FILE"
    write_base_hyprland_conf "$HYPR_CONFIG_FILE"
  fi

  echo "[OK] Installed config: $HYPR_CONFIG_FILE"
}

# Ensure Fedora users do not see qtutils warning if package is intentionally absent.
ensure_fedora_qtutils_check_disabled_in_file() {
  local config_file="$1"
  local tmp_file in_misc inserted

  if [[ "$DISTRO" != "fedora" || -z "$config_file" ]]; then
    return 0
  fi

  if [[ ! -f "$config_file" ]]; then
    return 0
  fi

  if grep -Eq 'disable_hyprland_qtutils_check[[:space:]]*=[[:space:]]*true' "$config_file" 2>/dev/null; then
    return 0
  fi

  if grep -Eq '^[[:space:]]*misc[[:space:]]*\{' "$config_file" 2>/dev/null; then
    tmp_file="$(mktemp)"
    in_misc=0
    inserted=0
    while IFS= read -r line; do
      echo "$line" >> "$tmp_file"
      if [[ "$line" =~ ^[[:space:]]*misc[[:space:]]*\{[[:space:]]*$ ]]; then
        in_misc=1
        continue
      fi
      if [[ "$in_misc" -eq 1 && "$line" =~ ^[[:space:]]*\}[[:space:]]*$ && "$inserted" -eq 0 ]]; then
        sed -i '$d' "$tmp_file"
        echo "    disable_hyprland_qtutils_check = true" >> "$tmp_file"
        echo "}" >> "$tmp_file"
        inserted=1
        in_misc=0
      fi
    done < "$config_file"
    mv "$tmp_file" "$config_file"
  else
    {
      echo
      echo "misc {"
      echo "    disable_hyprland_qtutils_check = true"
      echo "}"
    } >> "$config_file"
  fi

  echo "[OK] Fedora qtutils warning disabled in: $config_file"
}

