###############################################################################
# Top-level commands
###############################################################################

install() {
  detect_distro
  detect_package_manager
  install_packages
  install_config
  ensure_fedora_qtutils_check_disabled_in_file "$HYPR_CONFIG_FILE"

  # Reload active Hyprland session so updated binds/config take effect immediately.
  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  # Future staged installers (intentionally disabled)
  # install_stage_bar
  # install_stage_notifications
  # install_stage_launcher
  # install_stage_widgets
  # install_stage_utilities

  echo "Saga install complete"
}

doctor() {
  local item label cmd missing=0

  detect_distro

  for item in "${REQUIRED_COMPONENTS[@]}"; do
    label="${item%%|*}"
    cmd="${item##*|}"

    if command -v "$cmd" >/dev/null 2>&1; then
      echo "✓ $label installed"
    else
      echo "✗ $label missing"
      missing=1
    fi
  done

  if [[ -f "$HYPR_CONFIG_FILE" ]]; then
    echo "✓ hypr config present ($HYPR_CONFIG_FILE)"
  else
    echo "✗ hypr config missing ($HYPR_CONFIG_FILE)"
    missing=1
  fi

  if grep -Eq '^[[:space:]]*bind[[:space:]]*=.*\bT\b.*exec,[[:space:]]*(\$terminal_app|kitty)\b' "$HYPR_CONFIG_FILE" 2>/dev/null; then
    echo "✓ terminal bind present in hyprland.conf"
  else
    echo "✗ terminal bind missing in hyprland.conf"
    missing=1
  fi

  if [[ "$DISTRO" == "fedora" && -f "$HYPR_CONFIG_FILE" ]]; then
    if grep -Eq 'disable_hyprland_qtutils_check[[:space:]]*=[[:space:]]*true' "$HYPR_CONFIG_FILE"; then
      echo "✓ fedora qtutils warning disabled in ~/.config/hypr/hyprland.conf"
    else
      echo "✗ fedora qtutils warning setting missing in ~/.config/hypr/hyprland.conf"
      missing=1
    fi
  fi

  if [[ "$missing" -ne 0 ]]; then
    return 1
  fi
}

uninstall() {
  local target confirm
  local targets=(
    "$HOME/.config/hypr"
    "$HOME/.config/waybar"
    "$HOME/.config/walker"
    "$HOME/.config/eww"
    "$HOME/.config/swaync"
    "$HOME/.config/saga"
    "$HOME/.local/share/saga"
    "$HOME/.cache/saga"
    "$HOME/.local/bin/saga"
  )
  local pkg
  local to_remove=()

  detect_distro
  detect_package_manager

  for pkg in "${UNINSTALL_PACKAGES[@]}"; do
    if is_package_installed "$pkg"; then
      to_remove+=("$pkg")
    fi
  done

  echo "Saga will remove the following paths:"
  echo
  for target in "${targets[@]}"; do
    echo "$target"
  done
  echo
  if [[ "${#to_remove[@]}" -gt 0 ]]; then
    echo "Saga will also uninstall these system packages:"
    echo
    for pkg in "${to_remove[@]}"; do
      echo "$pkg"
    done
    echo
  else
    echo "No Saga-related system packages detected for removal."
    echo
  fi
  read -r -p "Continue? (y/n) " confirm

  case "$confirm" in
    y|Y)
      if [[ "${#to_remove[@]}" -gt 0 ]]; then
        echo "Removing Saga system packages..."
        case "$PKG_MANAGER" in
          dnf)
            if sudo dnf remove -y "${to_remove[@]}" >/dev/null; then
              for pkg in "${to_remove[@]}"; do
                echo "✓ $pkg uninstalled"
              done
            else
              echo "[ERROR] Failed to uninstall one or more packages" >&2
              exit 1
            fi
            ;;
          *)
            echo "[ERROR] Unsupported package manager for uninstall: $PKG_MANAGER" >&2
            exit 1
            ;;
        esac
      fi

      echo "Removing Saga configs..."
      for target in "${targets[@]}"; do
        if [[ -e "$target" ]]; then
          rm -rf "$target"
        fi
        echo "✓ $target removed"
      done
      echo "Saga uninstall complete"
      ;;
    *)
      echo "Uninstall cancelled"
      ;;
  esac
}

# CLI entrypoint.
main() {
  case "${1:-}" in
    install)
      install
      ;;
    uninstall)
      uninstall
      ;;
    doctor)
      doctor
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "[ERROR] Unknown command: $1" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
