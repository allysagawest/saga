#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SAGA_SHARE_DIR="$HOME/.local/share/saga"
SAGA_CACHE_DIR="$HOME/.cache/saga"
HYPR_CONFIG_DIR="$HOME/.config/hypr"
HYPR_CONFIG_FILE="$HYPR_CONFIG_DIR/hyprland.conf"
HYPR_BINDS_FILE="$HYPR_CONFIG_DIR/saga-binds.conf"
SHORTCUTS_FILE="$REPO_ROOT/config/shortcuts.json"
HYPR_TEMPLATE_FILE="$REPO_ROOT/hyprland_default.conf"

DISTRO=""
PKG_MANAGER=""

# package_label|binary_command
REQUIRED_COMPONENTS=(
  "hyprland|Hyprland"
  # Future baseline additions (disabled for now):
  # "pipewire|pipewire"
  # "wireplumber|wireplumber"
  # "xdg-desktop-portal-hyprland|xdg-desktop-portal-hyprland"
  # "wl-clipboard|wl-copy"
  # "grim|grim"
  # "slurp|slurp"
  "kitty|kitty"
  "swww|swww"
)

# Full package cleanup set for uninstall (Fedora stage).
# Keep this broader than the active install set so uninstall can clean older Saga attempts too.
UNINSTALL_PACKAGES=(
  hyprland
  pipewire
  wireplumber
  xdg-desktop-portal-hyprland
  wl-clipboard
  grim
  slurp
  kitty
  waybar
  walker
  eww
  swaynotificationcenter
  swww
  hyprlock
  hypridle
)

usage() {
  cat <<USAGE
Usage:
  ./cli/saga install
  ./cli/saga uninstall
  ./cli/saga doctor
USAGE
}

detect_distro() {
  if [[ ! -r /etc/os-release ]]; then
    echo "[ERROR] Cannot detect distro: /etc/os-release not found" >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  DISTRO="${ID:-unknown}"

  case "$DISTRO" in
    fedora)
      ;;
    *)
      echo "[ERROR] Unsupported distro: $DISTRO" >&2
      echo "[INFO] Currently supported: fedora" >&2
      exit 1
      ;;
  esac
}

detect_package_manager() {
  case "$DISTRO" in
    fedora)
      PKG_MANAGER="dnf"
      ;;
    *)
      echo "[ERROR] No package manager mapping for distro: $DISTRO" >&2
      exit 1
      ;;
  esac

  if ! command -v "$PKG_MANAGER" >/dev/null 2>&1; then
    echo "[ERROR] Package manager '$PKG_MANAGER' not found" >&2
    exit 1
  fi
}

is_package_installed() {
  local pkg="$1"
  case "$PKG_MANAGER" in
    dnf)
      rpm -q "$pkg" >/dev/null 2>&1
      ;;
    *)
      return 1
      ;;
  esac
}

install_single_package() {
  local pkg="$1"

  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
    return 0
  fi

  echo "[INSTALLING] $pkg"
  case "$PKG_MANAGER" in
    dnf)
      if sudo dnf install -y "$pkg" >/dev/null; then
        echo "[OK] $pkg"
      else
        echo "[ERROR] Failed to install package: $pkg" >&2
        exit 1
      fi
      ;;
    *)
      echo "[ERROR] Unsupported package manager: $PKG_MANAGER" >&2
      exit 1
      ;;
  esac
}

install_packages() {
  local item pkg _cmd
  for item in "${REQUIRED_COMPONENTS[@]}"; do
    pkg="${item%%|*}"
    _cmd="${item##*|}"
    install_single_package "$pkg"
  done
}

install_config() {
  local tmp_file
  mkdir -p "$HYPR_CONFIG_DIR" "$SAGA_SHARE_DIR" "$SAGA_CACHE_DIR"

  if [[ -f "$HYPR_TEMPLATE_FILE" ]]; then
    tmp_file="$(mktemp)"

    # Build from default template while removing keys Saga owns.
    awk '
      BEGIN { IGNORECASE=1 }
      # Saga-managed source/include
      /^[[:space:]]*source[[:space:]]*=[[:space:]]*~\/\.config\/hypr\/saga-binds\.conf[[:space:]]*$/ { next }
      # Saga-managed startup
      /^[[:space:]]*exec-once[[:space:]]*=[[:space:]]*swww-daemon[[:space:]]*$/ { next }
      # Remove conflicting default binds for keys Saga controls in baseline
      /^[[:space:]]*bind[[:space:]]*=/ {
        line = tolower($0)
        if (line ~ /, *return *,/ || line ~ /, *q *,/ || line ~ /, *m *,/) { next }
      }
      { print }
    ' "$HYPR_TEMPLATE_FILE" > "$tmp_file"

    {
      cat "$tmp_file"
      cat <<'CONF'

# --- Saga managed baseline ---
source = ~/.config/hypr/saga-binds.conf
exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec-once = swww-daemon
bind = SUPER, Q, killactive
bind = SUPER, M, exit

# Future stage placeholders (disabled for now):
# exec-once = waybar
# exec-once = swaync
# exec-once = walker
# exec-once = eww daemon
# exec-once = hypridle
CONF
    } > "$HYPR_CONFIG_FILE"

    rm -f "$tmp_file"
  else
    cat > "$HYPR_CONFIG_FILE" <<'CONF'
monitor=,preferred,auto,1
source = ~/.config/hypr/saga-binds.conf

exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

input {
    kb_layout = us
}

bind = SUPER, Q, killactive
bind = SUPER, M, exit
exec-once = swww-daemon

# Future stage placeholders (disabled for now):
# exec-once = waybar
# exec-once = swaync
# exec-once = walker
# exec-once = eww daemon
# exec-once = hypridle
CONF
  fi

  echo "[OK] Installed config: $HYPR_CONFIG_FILE"
}

shortcut_value() {
  local key="$1"
  local fallback="$2"
  local value=""

  if [[ -f "$SHORTCUTS_FILE" ]] && command -v jq >/dev/null 2>&1; then
    value="$(jq -r --arg k "$key" '.[$k] // empty' "$SHORTCUTS_FILE" 2>/dev/null || true)"
  fi

  if [[ -z "$value" || "$value" == "null" ]]; then
    echo "$fallback"
  else
    echo "$value"
  fi
}

to_hypr_bind_parts() {
  local shortcut="$1"
  local token key modifiers len i
  local parts=()

  IFS='+' read -ra raw_parts <<< "$shortcut"
  for token in "${raw_parts[@]}"; do
    token="$(echo "$token" | tr '[:lower:]' '[:upper:]' | xargs)"
    [[ "$token" == "ENTER" ]] && token="RETURN"
    parts+=("$token")
  done

  len="${#parts[@]}"
  if [[ "$len" -lt 2 ]]; then
    return 1
  fi

  key="${parts[$((len - 1))]}"
  modifiers=""
  for ((i=0; i<len-1; i++)); do
    if [[ -z "$modifiers" ]]; then
      modifiers="${parts[$i]}"
    else
      modifiers="$modifiers ${parts[$i]}"
    fi
  done

  printf '%s|%s\n' "$modifiers" "$key"
}

bind_line() {
  local shortcut="$1"
  local command="$2"
  local parsed modifiers key
  parsed="$(to_hypr_bind_parts "$shortcut")" || return 1
  modifiers="${parsed%%|*}"
  key="${parsed##*|}"
  printf 'bind = %s, %s, exec, %s\n' "$modifiers" "$key" "$command"
}

generate_binds() {
  local terminal launcher notifications

  terminal="$(shortcut_value terminal "SUPER+RETURN")"
  launcher="$(shortcut_value launcher "SUPER+SPACE")"
  notifications="$(shortcut_value notifications "SUPER+ALT+N")"

  {
    echo "# Generated by Saga"
    echo
    bind_line "$terminal" "kitty"
    echo
    # Stage placeholders written from shortcuts config (disabled until implemented):
    echo "# $(bind_line "$launcher" "walker" 2>/dev/null || echo 'launcher shortcut invalid')"
    echo "# $(bind_line "$notifications" "swaync-client -t" 2>/dev/null || echo 'notifications shortcut invalid')"
  } > "$HYPR_BINDS_FILE"

  echo "[OK] Installed binds: $HYPR_BINDS_FILE"
}

