#!/usr/bin/env bash
set -euo pipefail

SAGA_SHARE_DIR="$HOME/.local/share/saga"
SAGA_CACHE_DIR="$HOME/.cache/saga"
HYPR_CONFIG_DIR="$HOME/.config/hypr"
HYPR_CONFIG_FILE="$HYPR_CONFIG_DIR/hyprland.conf"

DISTRO=""
PKG_MANAGER=""

# package_label|binary_command
REQUIRED_COMPONENTS=(
  "hyprland|Hyprland"
  # Future baseline additions (disabled for now):
  # "pipewire|pipewire"
  # "wireplumber|wireplumber"
  # "xdg-desktop-portal-hyprland|xdg-desktop-portal-hyprland"
  # "wl-clipboard|wl-copy"
  # "grim|grim"
  # "slurp|slurp"
  # "kitty|kitty"
)

# Full package cleanup set for uninstall (Fedora stage).
# Keep this broader than the active install set so uninstall can clean older Saga attempts too.
UNINSTALL_PACKAGES=(
  hyprland
  pipewire
  wireplumber
  xdg-desktop-portal-hyprland
  wl-clipboard
  grim
  slurp
  kitty
  waybar
  walker
  eww
  swaynotificationcenter
  swww
  hyprlock
  hypridle
)

usage() {
  cat <<USAGE
Usage:
  ./cli/saga install
  ./cli/saga uninstall
  ./cli/saga doctor
USAGE
}

detect_distro() {
  if [[ ! -r /etc/os-release ]]; then
    echo "[ERROR] Cannot detect distro: /etc/os-release not found" >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  DISTRO="${ID:-unknown}"

  case "$DISTRO" in
    fedora)
      ;;
    *)
      echo "[ERROR] Unsupported distro: $DISTRO" >&2
      echo "[INFO] Currently supported: fedora" >&2
      exit 1
      ;;
  esac
}

detect_package_manager() {
  case "$DISTRO" in
    fedora)
      PKG_MANAGER="dnf"
      ;;
    *)
      echo "[ERROR] No package manager mapping for distro: $DISTRO" >&2
      exit 1
      ;;
  esac

  if ! command -v "$PKG_MANAGER" >/dev/null 2>&1; then
    echo "[ERROR] Package manager '$PKG_MANAGER' not found" >&2
    exit 1
  fi
}

is_package_installed() {
  local pkg="$1"
  case "$PKG_MANAGER" in
    dnf)
      rpm -q "$pkg" >/dev/null 2>&1
      ;;
    *)
      return 1
      ;;
  esac
}

install_single_package() {
  local pkg="$1"

  if is_package_installed "$pkg"; then
    echo "[OK] $pkg"
    return 0
  fi

  echo "[INSTALLING] $pkg"
  case "$PKG_MANAGER" in
    dnf)
      if sudo dnf install -y "$pkg" >/dev/null; then
        echo "[OK] $pkg"
      else
        echo "[ERROR] Failed to install package: $pkg" >&2
        exit 1
      fi
      ;;
    *)
      echo "[ERROR] Unsupported package manager: $PKG_MANAGER" >&2
      exit 1
      ;;
  esac
}

install_packages() {
  local item pkg _cmd
  for item in "${REQUIRED_COMPONENTS[@]}"; do
    pkg="${item%%|*}"
    _cmd="${item##*|}"
    install_single_package "$pkg"
  done
}

install_config() {
  mkdir -p "$HYPR_CONFIG_DIR" "$SAGA_SHARE_DIR" "$SAGA_CACHE_DIR"

  cat > "$HYPR_CONFIG_FILE" <<'CONF'
monitor=,preferred,auto,1

exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

input {
    kb_layout = us
}

bind = SUPER, Q, killactive
bind = SUPER, M, exit

# Future stage placeholders (disabled for now):
# bind = SUPER, RETURN, exec, kitty
# exec-once = waybar
# exec-once = swaync
# exec-once = walker
# exec-once = eww daemon
# exec-once = swww-daemon
# exec-once = hypridle
CONF

  echo "[OK] Installed config: $HYPR_CONFIG_FILE"
}

install_stage_bar() {
  # Placeholder for future stage: waybar install/config
  :
}

install_stage_notifications() {
  # Placeholder for future stage: swaync install/config
  :
}

install_stage_launcher() {
  # Placeholder for future stage: launcher install/config
  :
}

install_stage_widgets() {
  # Placeholder for future stage: eww/widgets install/config
  :
}

install_stage_utilities() {
  # Placeholder for future stage: extra desktop utilities
  :
}

install() {
  detect_distro
  detect_package_manager
  install_packages
  install_config

  # Future staged installers (intentionally disabled)
  # install_stage_bar
  # install_stage_notifications
  # install_stage_launcher
  # install_stage_widgets
  # install_stage_utilities

  echo "Saga install complete"
}

doctor() {
  local item label cmd missing=0

  for item in "${REQUIRED_COMPONENTS[@]}"; do
    label="${item%%|*}"
    cmd="${item##*|}"

    if command -v "$cmd" >/dev/null 2>&1; then
      echo "✓ $label installed"
    else
      echo "✗ $label missing"
      missing=1
    fi
  done

  if [[ -f "$HYPR_CONFIG_FILE" ]]; then
    echo "✓ hypr config present ($HYPR_CONFIG_FILE)"
  else
    echo "✗ hypr config missing ($HYPR_CONFIG_FILE)"
    missing=1
  fi

  if [[ "$missing" -ne 0 ]]; then
    return 1
  fi
}

uninstall() {
  local target confirm
  local targets=(
    "$HOME/.config/hypr"
    "$HOME/.config/waybar"
    "$HOME/.config/walker"
    "$HOME/.config/eww"
    "$HOME/.config/swaync"
    "$HOME/.config/saga"
    "$HOME/.local/share/saga"
    "$HOME/.cache/saga"
    "$HOME/.local/bin/saga"
  )
  local pkg
  local to_remove=()

  detect_distro
  detect_package_manager

  for pkg in "${UNINSTALL_PACKAGES[@]}"; do
    if is_package_installed "$pkg"; then
      to_remove+=("$pkg")
    fi
  done

  echo "Saga will remove the following paths:"
  echo
  for target in "${targets[@]}"; do
    echo "$target"
  done
  echo
  if [[ "${#to_remove[@]}" -gt 0 ]]; then
    echo "Saga will also uninstall these system packages:"
    echo
    for pkg in "${to_remove[@]}"; do
      echo "$pkg"
    done
    echo
  else
    echo "No Saga-related system packages detected for removal."
    echo
  fi
  read -r -p "Continue? (y/n) " confirm

  case "$confirm" in
    y|Y)
      if [[ "${#to_remove[@]}" -gt 0 ]]; then
        echo "Removing Saga system packages..."
        case "$PKG_MANAGER" in
          dnf)
            if sudo dnf remove -y "${to_remove[@]}" >/dev/null; then
              for pkg in "${to_remove[@]}"; do
                echo "✓ $pkg uninstalled"
              done
            else
              echo "[ERROR] Failed to uninstall one or more packages" >&2
              exit 1
            fi
            ;;
          *)
            echo "[ERROR] Unsupported package manager for uninstall: $PKG_MANAGER" >&2
            exit 1
            ;;
        esac
      fi

      echo "Removing Saga configs..."
      for target in "${targets[@]}"; do
        if [[ -e "$target" ]]; then
          rm -rf "$target"
        fi
        echo "✓ $target removed"
      done
      echo "Saga uninstall complete"
      ;;
    *)
      echo "Uninstall cancelled"
      ;;
  esac
}

main() {
  case "${1:-}" in
    install)
      install
      ;;
    uninstall)
      uninstall
      ;;
    doctor)
      doctor
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "[ERROR] Unknown command: $1" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
